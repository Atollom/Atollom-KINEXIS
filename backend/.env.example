# KINEXIS - Configuracion de Integraciones
# Copiar a .env y rellenar con credenciales reales

# ===========================================
# GENERAL
# ===========================================
ENVIRONMENT=sandbox  # sandbox | production

# ===========================================
# MERCADO LIBRE
# Docs: https://developers.mercadolibre.com.mx/
# ===========================================
ML_CLIENT_ID=your_app_id_here
ML_CLIENT_SECRET=your_secret_here
ML_REDIRECT_URI=http://localhost:3000/api/integrations/ml/callback

# Test User (solo sandbox)
ML_TEST_USER_ID=123456789
ML_TEST_ACCESS_TOKEN=TEST-123456-abcdef

# ===========================================
# AMAZON SP-API
# Docs: https://developer-docs.amazon.com/sp-api/
# ===========================================
AMAZON_SELLER_ID=your_seller_id
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER  # US | A1AM78C64UM0Y8 = MX
AMAZON_LWA_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxx
AMAZON_LWA_CLIENT_SECRET=your_lwa_client_secret
AMAZON_AWS_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
AMAZON_AWS_SECRET_KEY=your_aws_secret_key
AMAZON_ROLE_ARN=arn:aws:iam::123456789012:role/KinexisAmazon
AMAZON_REFRESH_TOKEN=Atzr|your_refresh_token_here
# Legacy aliases (kept for backwards compat)
AMAZON_ACCESS_KEY=your_access_key
AMAZON_SECRET_KEY=your_secret_key

# ===========================================
# SHOPIFY
# Docs: https://shopify.dev/docs/api
# ===========================================
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-04

# ===========================================
# META (WhatsApp, Instagram, Facebook)
# Docs: https://developers.facebook.com/docs/whatsapp/cloud-api
# ===========================================
META_ACCESS_TOKEN=your_meta_access_token
META_PHONE_NUMBER_ID=123456789012345
META_WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
META_VERIFY_TOKEN=your_webhook_verify_token

# Instagram
META_INSTAGRAM_ACCOUNT_ID=123456789

# Facebook Page
META_FACEBOOK_PAGE_ID=123456789

# ===========================================
# STRIPE
# Docs: https://docs.stripe.com/
# ===========================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx  # Test key
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ===========================================
# FACTURAMA (Primary CFDI Provider)
# Docs: https://apisandbox.facturama.mx/
# ===========================================
FACTURAMA_USER=your_sandbox_user
FACTURAMA_PASSWORD=your_sandbox_password
FACTURAMA_SANDBOX=true  # true en desarrollo

# ===========================================
# FACTURAPI (Fallback CFDI Provider)
# Docs: https://www.facturapi.io/docs
# ===========================================
FACTURAPI_SECRET_KEY=sk_test_xxxxxxxxxxxxx
FACTURAPI_SANDBOX=true

# ===========================================
# SUPABASE (Auth + Database + Storage)
# Docs: https://supabase.com/dashboard/project/_/settings/api
# ===========================================
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # NUNCA exponer al frontend
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_dashboard

# ===========================================
# DATABASE (PostgreSQL via Supabase — connection string directa)
# ===========================================
DATABASE_URL=postgresql://postgres:your_password@db.your_project.supabase.co:5432/postgres

# ===========================================
# ENCRYPTION (API Credentials at rest)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ===========================================
ENCRYPTION_KEY=your_fernet_key_here_44_chars_base64

# ===========================================
# EMAIL (Resend — para emails de bienvenida y notificaciones)
# Docs: https://resend.com/api-keys
# ===========================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=KINEXIS <onboarding@atollom.com>
DASHBOARD_URL=https://dashboard.atollom.com

# ===========================================
# SKYDROPX (Envios)
# Docs: https://developers.skydropx.com/
# ===========================================
SKYDROPX_API_KEY=your_api_key
SKYDROPX_SANDBOX=true
